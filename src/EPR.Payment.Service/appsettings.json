{
    "ConnectionStrings": {
        "PaymentConnectionString": ""
    },
    "Serilog": {
        "Using": [
            "Serilog",
            "Serilog.Sinks.ApplicationInsights"
        ],
        "MinimumLevel": {
            "Default": "Information",
            "Override": {
                "Microsoft.AspNetCore": "Warning",
                "Microsoft.FeatureManagement": "Information"
            }
        },
        "Enrich": [
            "FromLogContext",
            "WithEnvironmentName",
            "WithProcessId"
        ],
        "WriteTo": [
            {
                "Name": "Console",
                "Args": {
                    "outputTemplate": "{Timestamp:yyyy-MM-dd'T'HH:mm:ss.ffffff} {Level:u3} {Message:lj}{NewLine}{Properties}{NewLine}{Exception}",
                    "theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console"
                }
            },
            {
                "Name": "ApplicationInsights",
                "Args": {
                    "telemetryConverter": "Serilog.Sinks.ApplicationInsights.TelemetryConverters.TraceTelemetryConverter, Serilog.Sinks.ApplicationInsights"
                }
            }
        ]
    },
    "AllowedHosts": "*",
    "FeatureManagement": {
        "EnableOnlinePaymentsFeature": true,
        "EnableOnlinePaymentInsert": true,
        "EnableOnlinePaymentInsertV2": true,
        "EnableOnlinePaymentUpdate": true,
        "EnableGetOnlinePaymentByExternalPaymentId": true,
        "EnableRegistrationFeesFeature": true,
        "EnableRegistrationFeesCalculation": true,
        "EnableProducersResubmissionFeesFeature": true,
        "EnableProducerResubmissionFee": true,
        "EnableComplianceSchemeFeature": true,
        "EnableComplianceSchemeFees": true,
        "EnableResubmissionComplianceSchemeFeature": true,
        "EnableResubmissionFeesCalculation": true,
        "EnableResubmissionProducerMemberCountBaseFeeMultiplication": false,
        "EnableOfflinePaymentsFeature": true,
        "EnableOfflinePayment": true,
        "EnableOfflinePaymentV2": true,
        "EnableReprocessorExporterAccreditationFeesFeature": true,
        "EnableReprocessorExporterAccreditationFeesCalculation": true,
        "EnableReprocessorOrExporterRegistrationFeesFeature": true,
        "EnableReprocessorOrExporterRegistrationFeesCalculation": true
    },
    "StorageAccount": {
      "ConnectionString": "",
      "RegistrationContainer": "registration-upload-container"
    },
    "ServiceBus": {
        "ConnectionString": "",
        "AdminConnectionString": "",
        "TopicName": "defra.epr.registration.submit.for.fees",
        "SubscriptionName": "registration-submitted-payment-service"
    },
    "RunMigration": false
}